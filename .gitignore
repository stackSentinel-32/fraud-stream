venv/
env/
.venv/
ENV/

# ── IDE / editor ──────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*.suo
.project
.classpath

# ── OS artifacts ──────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
Desktop.ini

