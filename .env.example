# ─────────────────────────────────────────────────────────────────
# fraud-stream · Environment Variables
#
# Copy this file to .env and fill in real values.
# NEVER commit .env — it is in .gitignore.
# ─────────────────────────────────────────────────────────────────

# ── Kafka ──────────────────────────────────────────────────────────
# localhost:9092  → when running Python scripts directly on your host
# kafka:29092     → when running Python scripts inside a Docker container
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC=transactions
KAFKA_GROUP_ID=fraud-consumer-group
KAFKA_MAX_RETRIES=5

# ── Producer ───────────────────────────────────────────────────────
PAYSIM_PATH=data/paysim.csv
PRODUCER_MIN_DELAY=0.1
PRODUCER_MAX_DELAY=1.0
PRODUCER_LOG_INTERVAL=100

# ── PostgreSQL ────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=fraud_user
POSTGRES_PASSWORD=changeme_in_real_env
POSTGRES_DB=frauddb

# ── Model ─────────────────────────────────────────────────────────
DATA_PATH=data/creditcard.csv
MODEL_PATH=model/model.pkl
FEATURE_COLUMNS_PATH=model/feature_columns.json

# ── API ───────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_BASE_URL=http://localhost:8000
API_TIMEOUT_S=5

# ── Logging ───────────────────────────────────────────────────────
LOG_LEVEL=INFO
